# Copia in .env (non committare).

NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Dettagli annunci: da PostgreSQL (tabella gestim_listings) — consigliato
LISTING_SOURCE=database
# Opzione A — URL unico:
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
# Opzione B — variabili separate (es. Render / Scaleway), senza URL:
# DB_HOST=
# DB_PORT=5432
# DB_USER=
# DB_PASSWORD=
# DB_NAME=
# DB_SSL=true
# TLS_CERT="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"
# Solo se usi ancora l'API HTTP invece del DB:
# LISTING_SOURCE=api
# GESTIM_API_BASE_URL=https://tuo-backend.example.com

# Google — una delle due:
# Esempio locale (file nella root del progetto; non committare il JSON):
# GOOGLE_APPLICATION_CREDENTIALS=./megaron-493608-9fc8ca550180.json
GOOGLE_APPLICATION_CREDENTIALS=/percorso/service-account.json
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# --- Mappa zona → nome tab (scegli UNA tra foglio mapping o JSON) ---

# Opzione 1: tab "mapping" nello stesso file: col A = zona, col B = nome foglio destinazione (senza riga header)
MAPPING_SPREADSHEET_ID=1TeCxH0BRETny1P-3-Rf65_EYMly1YGvpibYZtnzpTT0
MAPPING_SHEET_NAME=mapping
MAPPING_ZONE_MATCH=contains
# DEFAULT_SPREADSHEET_ID opzionale: default = MAPPING_SPREADSHEET_ID

# Opzione 2: regole in JSON (allora DEFAULT_SPREADSHEET_ID è obbligatorio se non usi MAPPING_SPREADSHEET_ID)
# DEFAULT_SPREADSHEET_ID=your_default_spreadsheet_id
# ZONE_SHEET_MAP_JSON=[{"name":"Prati","pattern":"Prati","match":"contains","spreadsheetId":"ID","sheetTitle":"Prati"}]

DEFAULT_SHEET_TITLE=Lead

# UNMAPPED_ZONE_SPREADSHEET_ID=
# UNMAPPED_ZONE_SHEET_TITLE=Errori

# EXTRA_ID_REGEX=GESTIM-([A-Z0-9]{6,})

# --- Worker Microsoft Graph (npm run start:worker) ---
# GRAPH_TENANT_ID=
# GRAPH_CLIENT_ID=
# GRAPH_CLIENT_SECRET=
# MAILBOX_USER=megaron@tuodominio.it
# WORKER_POLL_INTERVAL_MINUTES=60
# GRAPH_LOOKBACK_HOURS=24
# GRAPH_STATE_SPREADSHEET_ID=
# GRAPH_STATE_SHEET_NAME=_graph_processed
